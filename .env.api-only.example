# ============================================================
# STARVIS - API-only self-host configuration
# Usage:
#   cp .env.api-only.example .env.api-only
#   docker compose -f docker-compose.api-only.yml --env-file .env.api-only up -d
# ============================================================

# Docker project / images
COMPOSE_PROJECT_NAME=starvis-api
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
API_IMAGE=ghcr.io/ampynjord/starvis-api:latest

# Public API binding.
# Use "3000" to bind on all interfaces, or "127.0.0.1:3000" behind a reverse proxy.
API_PORT=127.0.0.1:3000

# PostgreSQL exposed on localhost for the extractor CLI.
DB_EXTERNAL_PORT=5432
DB_NAME=starvis
DB_USER=starvis_user
DB_PASSWORD=change_me_strong_password

# Security
JWT_SECRET=change_me_random_64chars_minimum
ADMIN_API_KEY=change_me_admin_key
AUTH_COOKIE_NAME=starvis_token
CORS_ORIGIN=https://your-domain.example

# Redis
REDIS_MAXMEMORY=64mb
REDIS_PASSWORD=

# Rate limiting
RATE_LIMIT_MAX=500
RATE_LIMIT_BURST=50
RATE_LIMIT_ADMIN_MAX=100

# Logging / cache
LOG_LEVEL=info

# AI chat provider (optional; leave key empty to disable successful chat calls)
MISTRAL_API_KEY=
CHAT_PROVIDER_BASE_URL=https://api.mistral.ai/v1
CHAT_TOOL_MODEL=mistral-small-latest
CHAT_RESPONSE_MODEL=mistral-small-latest

# Email notifications / auth mail (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CONTACT_EMAIL=

# Extractor helper values for local runs:
#   DB_HOST=127.0.0.1
#   DB_PORT=${DB_EXTERNAL_PORT}
#   DB_USER=${DB_USER}
#   DB_PASSWORD=${DB_PASSWORD}
#   DB_NAME=${DB_NAME}
