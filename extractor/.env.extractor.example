# ============================================================
# STARVIS Extractor — Variables d'environnement
# Usage : cp .env.extractor.example .env.extractor && tsx extract.ts
#         ou : tsx extract.ts --p4k /chemin/vers/Data.p4k
#
# L'extractor tourne en local (pas dans Docker) et écrit
# directement dans la base MySQL (dev ou prod via tunnel SSH).
# ============================================================

# --- Base de données cible ---
DB_HOST=127.0.0.1            # localhost pour dev, ou IP VPS via tunnel SSH
DB_PORT=3306                 # Dev: port exposé docker-compose.dev.yml (3306)
                             # Prod via tunnel: ssh -L 3306:localhost:3306 user@vps
DB_USER=starvis_user
DB_PASSWORD=change_me
DB_NAME=starvis

# --- Fichier P4K Star Citizen ---
# Peut aussi être passé en argument CLI : tsx extract.ts --p4k /chemin/Data.p4k
P4K_PATH=/home/user/StarCitizen/LIVE/Data.p4k

# --- Log ---
LOG_LEVEL=info               # debug | info | warn | error

# --- Optional external canonical sources (JSON files) ---
# If set, extractor merges these overrides by className and prefers higher confidence.
# JSON shape:
# {
#   "items": [{"className":"...","name":"...","sourceType":"cornerstone","sourceName":"cornerstone","confidenceScore":85}],
#   "commodities": [...],
#   "components": [...],
#   "shops": [...]
# }
STARVIS_CORNERSTONE_CANONICAL_JSON=
STARVIS_COMMUNITY_CANONICAL_JSON=

# Optional HTTP endpoints returning equivalent JSON shape.
# If both JSON path and URL are set, local JSON is used first.
STARVIS_CORNERSTONE_CANONICAL_URL=
STARVIS_COMMUNITY_CANONICAL_URL=

# Optional auth for Cornerstone URL
STARVIS_CORNERSTONE_API_KEY=
STARVIS_CORNERSTONE_AUTH_HEADER=X-API-Key

# Dry run helper:
# npm run dry-run:adapters -- --sample 5
