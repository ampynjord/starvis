{
  "name": "@starvis/extractor",
  "version": "1.0.0",
  "description": "Starvis P4K/DataForge extractor — runs locally, pushes game data to PostgreSQL",
  "main": "extract.ts",
  "type": "module",
  "scripts": {
    "extract": "tsx extract.ts",
    "wizard": "tsx src/cli/wizard.ts",
    "audit:locations": "tsx scripts/audit-locations.ts",
    "audit:static-data": "tsx scripts/audit-static-data.ts",
    "dev": "tsx watch extract.ts",
    "lint": "biome check --write .",
    "lint:ci": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "author": "ampynjord - Dawnstar",
  "license": "UNLICENSED",
  "dependencies": {
    "@starvis/db": "*",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "fzstd": "^0.1.1",
    "pg": "^8.12.0",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.11.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  }
}
