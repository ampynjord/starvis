{
  "name": "@starvis/extractor",
  "version": "1.0.0",
  "description": "Starvis P4K/DataForge extractor — runs locally, pushes game data to PostgreSQL",
  "main": "extract.ts",
  "type": "module",
  "scripts": {
    "extract": "tsx extract.ts",
    "audit:quality": "tsx scripts/audit-quality.ts",
    "dry-run:adapters": "tsx scripts/dry-run-adapters.ts",
    "dev": "tsx watch extract.ts",
    "lint": "biome check --write .",
    "lint:ci": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "ampynjord - Dawnstar",
  "license": "UNLICENSED",
  "dependencies": {
    "commander": "^13.1.0",
    "dotenv": "^16.3.1",
    "fzstd": "^0.1.1",
    "pg": "^8.12.0",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^20.19.35",
    "@types/pg": "^8.11.0",
    "tsx": "^4.22.4",
    "typescript": "^5.3.3",
    "vitest": "^4.1.8"
  }
}
