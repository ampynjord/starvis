{
  "name": "starvis-extractor",
  "version": "1.0.0",
  "description": "Starvis P4K/DataForge extractor — runs locally, pushes game data to MySQL",
  "main": "extract.ts",
  "type": "module",
  "scripts": {
    "extract": "tsx extract.ts",
    "audit:quality": "tsx scripts/audit-quality.ts",
    "dry-run:adapters": "tsx scripts/dry-run-adapters.ts",

    "dev": "tsx watch extract.ts",
    "lint": "biome check --write .",
    "lint:ci": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "author": "ampynjord - Dawnstar",
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0",
    "dotenv": "^16.3.1",
    "fzstd": "^0.1.1",
    "mysql2": "^3.16.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
