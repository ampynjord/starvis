# ============================================================
# STARVIS Extractor — Configuration
# Usage : cp .env.example .env.dev   (ou .env.prod)
#
# L'extractor tourne en LOCAL (pas dans Docker).
# Il écrit directement dans la base PostgreSQL :
#   - Dev  : base exposée par docker-compose.dev.yml (port 5432 sur l'hôte)
#   - Prod : via tunnel SSH : ssh -L 5432:localhost:5432 user@vps
#
# Sélection au lancement :
#   npx tsx extract.ts              → charge .env.dev  (défaut)
#   npx tsx extract.ts --prod-db    → charge .env.prod
# ============================================================

# --- Base de données PostgreSQL (schémas : game / rsi / meta) ---
# Option 1 : URL complète (prioritaire si renseignée)
# DATABASE_URL=postgresql://starvis_user:change_me@127.0.0.1:5432/starvis

# Option 2 : paramètres individuels
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=starvis_user
DB_PASSWORD=change_me
DB_NAME=starvis

# --- Fichier P4K Star Citizen ---
# Peut aussi être passé en argument CLI : --p4k /chemin/Data.p4k
# Base de chemin Windows : %PROGRAMFILES%\Roberts Space Industries\StarCitizen\
# Puis choisir le canal :
#   LIVE\Data.p4k
#   PTU\Data.p4k
# Chemins automatiques détectés :
#   Windows : %PROGRAMFILES%\Roberts Space Industries\StarCitizen\LIVE\Data.p4k
# Variables recommandées (prioritaires selon --env)
P4K_LIVE_PATH=
P4K_PTU_PATH=
# Fallback générique (si les variables ci-dessus sont vides)
P4K_PATH=

# --- Cache CTM (modèles 3D) ---
CTM_CACHE_DIR=./ctm-cache

# --- Log ---
LOG_LEVEL=info               # debug | info | warn | error
