# ============================================================
# STARVIS Extractor — Configuration
# Usage : cp .env.example .env.dev   (ou .env.prod)
#
# L'extractor tourne en LOCAL (pas dans Docker).
# Il écrit directement dans la base MySQL :
#   - Dev  : base exposée par docker-compose.dev.yml (port 3306 sur l'hôte)
#   - Prod : via tunnel SSH : ssh -L 3306:localhost:3306 user@vps
#
# Sélection au lancement :
#   npx tsx extract.ts              → charge .env.dev  (défaut)
#   npx tsx extract.ts --prod-db    → charge .env.prod
# ============================================================

# --- Base de données principale (starvis) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=starvis_user
DB_PASSWORD=change_me
DB_NAME=starvis

# --- Base de données jeu (live / ptu) ---
# Les modules P4K écrivent dans la DB correspondant à --env live|ptu
# Pas besoin de les déclarer ici : la DB est dérivée du paramètre --env

# --- Fichier P4K Star Citizen ---
# Peut aussi être passé en argument CLI : --p4k /chemin/Data.p4k
# Chemins automatiques détectés :
#   Windows : %PROGRAMFILES%\Roberts Space Industries\StarCitizen\LIVE\Data.p4k
#   macOS   : ~/Library/Application Support/Roberts Space Industries/StarCitizen/LIVE/Data.p4k
P4K_PATH=

# --- Cache CTM (modèles 3D) ---
CTM_CACHE_DIR=./ctm-cache

# --- Log ---
LOG_LEVEL=info               # debug | info | warn | error
