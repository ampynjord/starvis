// ============================================================
// rsi.prisma — Schema for the rsi_website database
// Contains: data scraped from RSI website and SC Wiki API.
// Does NOT contain: game data (live/ptu), extraction metadata (starvis)
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../generated/rsi"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Ship Matrix (RSI website) ────────────────────────────────────────────────

model ShipMatrix {
  id                Int      @id
  name              String   @db.VarChar(255)
  chassisId         Int?     @map("chassis_id")
  manufacturerCode  String?  @map("manufacturer_code") @db.VarChar(10)
  manufacturerName  String?  @map("manufacturer_name") @db.VarChar(100)
  focus             String?  @db.VarChar(255)
  type              String?  @db.VarChar(50)
  description       String?  @db.Text
  productionStatus  String?  @map("production_status") @db.VarChar(50)
  productionNote    String?  @map("production_note") @db.Text
  size              String?  @db.VarChar(20)
  url               String?  @db.VarChar(500)
  length            Decimal? @db.Decimal(10, 2)
  beam              Decimal? @db.Decimal(10, 2)
  height            Decimal? @db.Decimal(10, 2)
  mass              Int?
  cargocapacity     Int?
  minCrew           Int?     @default(1) @map("min_crew")
  maxCrew           Int?     @default(1) @map("max_crew")
  scmSpeed          Int?     @map("scm_speed")
  afterburnerSpeed  Int?     @map("afterburner_speed")
  pitchMax          Decimal? @map("pitch_max") @db.Decimal(10, 2)
  yawMax            Decimal? @map("yaw_max") @db.Decimal(10, 2)
  rollMax           Decimal? @map("roll_max") @db.Decimal(10, 2)
  xaxisAcceleration Decimal? @map("xaxis_acceleration") @db.Decimal(10, 4)
  yaxisAcceleration Decimal? @map("yaxis_acceleration") @db.Decimal(10, 4)
  zaxisAcceleration Decimal? @map("zaxis_acceleration") @db.Decimal(10, 4)
  mediaSourceUrl    String?  @map("media_source_url") @db.Text
  mediaStoreSmall   String?  @map("media_store_small") @db.Text
  mediaStoreLarge   String?  @map("media_store_large") @db.Text
  compiled          Json?
  syncedAt          DateTime @default(now()) @map("synced_at") @db.DateTime(0)

  @@map("ship_matrix")
}

// ─── Galactapedia ─────────────────────────────────────────────────────────────

model Galactapedia {
  id           String   @id @db.VarChar(50)
  slug         String   @db.VarChar(255)
  title        String   @db.VarChar(500)
  content      String?  @db.LongText
  excerpt      String?  @db.VarChar(500)
  categories   Json?
  tags         Json?
  thumbnailUrl String?  @map("thumbnail_url") @db.VarChar(500)
  rsiUrl       String?  @map("rsi_url") @db.VarChar(500)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)

  @@index([slug], map: "idx_galactapedia_slug")
  @@map("galactapedia")
}

// ─── Comm-links ───────────────────────────────────────────────────────────────

model CommLink {
  id           Int       @id @default(autoincrement())
  rsiId        String    @unique @map("rsi_id") @db.VarChar(20)
  slug         String?   @db.VarChar(255)
  title        String    @db.VarChar(500)
  content      String?   @db.LongText
  excerpt      String?   @db.VarChar(500)
  category     String?   @db.VarChar(100)
  thumbnailUrl String?   @map("thumbnail_url") @db.VarChar(500)
  rsiUrl       String?   @map("rsi_url") @db.VarChar(500)
  publishedAt  DateTime? @map("published_at") @db.DateTime(0)

  @@index([category], map: "idx_commlink_category")
  @@index([publishedAt], map: "idx_commlink_published_at")
  @@map("comm_links")
}

// ─── Starmap locations (RSI web starmap) ─────────────────────────────────────

model StarmapLocation {
  id           Int      @id @default(autoincrement())
  rsiId        String   @unique @map("rsi_id") @db.VarChar(50)
  name         String   @db.VarChar(255)
  type         String   @db.VarChar(50)
  systemCode   String?  @map("system_code") @db.VarChar(20)
  systemName   String?  @map("system_name") @db.VarChar(255)
  parentId     String?  @map("parent_id") @db.VarChar(50)
  factionName  String?  @map("faction_name") @db.VarChar(100)
  affiliations Json?
  thumbnail    String?  @db.VarChar(500)
  description  String?  @db.Text
  coordinates  Json?
  jumpPoints   Json?    @map("jump_points")
  syncedAt     DateTime @default(now()) @map("synced_at") @db.DateTime(0)

  @@index([systemCode], map: "idx_starmap_system_code")
  @@index([type], map: "idx_starmap_type")
  @@map("starmap_locations")
}
