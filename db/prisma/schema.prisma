// ============================================================
// schema.prisma — Unified PostgreSQL multi-schema definition
//
// Schemas:
//   game  — game data extracted from P4K (ships, components, manufacturers…)
//            env = "live" | "ptu" replaces the live/ptu DB split
//   rsi   — data scraped from RSI website / SC Wiki
//   meta  — extraction metadata, changelogs, users
//
// Run: npm run generate --workspace=@starvis/db
// ============================================================

generator client {
  provider        = "prisma-client-js"
  output          = "../generated/client"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["game", "rsi", "meta"]
}

// ╔══════════════════════════════════════════════════════════════╗
// ║  META SCHEMA — extraction log, changelog, users              ║
// ╚══════════════════════════════════════════════════════════════╝

enum ExtractionStatus {
  success
  partial
  failed

  @@schema("meta")
}

enum ChangelogEntityType {
  ship
  component
  item
  commodity
  shop
  module
  recipe

  @@schema("meta")
}

enum ChangelogChangeType {
  added
  removed
  modified

  @@schema("meta")
}

model ExtractionLog {
  id                 Int              @id @default(autoincrement())
  extractionHash     String           @map("extraction_hash") @db.Char(64)
  gameVersion        String?          @map("game_version") @db.VarChar(50)
  gameEnv            String           @default("live") @map("game_env") @db.VarChar(10)
  shipsCount         Int              @default(0) @map("ships_count")
  componentsCount    Int              @default(0) @map("components_count")
  itemsCount         Int              @default(0) @map("items_count")
  commoditiesCount   Int              @default(0) @map("commodities_count")
  manufacturersCount Int              @default(0) @map("manufacturers_count")
  loadoutPortsCount  Int              @default(0) @map("loadout_ports_count")
  shopsCount         Int              @default(0) @map("shops_count")
  recipesCount       Int              @default(0) @map("recipes_count")
  durationMs         Int?             @map("duration_ms")
  status             ExtractionStatus @default(success)
  errorMessage       String?          @map("error_message")
  extractedAt        DateTime         @default(now()) @map("extracted_at")

  changelogs Changelog[]

  @@index([extractionHash])
  @@index([gameEnv])
  @@map("extraction_log")
  @@schema("meta")
}

model Changelog {
  id           Int                 @id @default(autoincrement())
  extractionId Int                 @map("extraction_id")
  entityType   ChangelogEntityType @map("entity_type")
  entityUuid   String              @map("entity_uuid") @db.VarChar(255)
  entityName   String?             @map("entity_name") @db.VarChar(255)
  changeType   ChangelogChangeType @map("change_type")
  fieldName    String?             @map("field_name") @db.VarChar(100)
  oldValue     String?             @map("old_value")
  newValue     String?             @map("new_value")
  createdAt    DateTime            @default(now()) @map("created_at")

  extraction ExtractionLog @relation(fields: [extractionId], references: [id], onDelete: Cascade)

  @@index([extractionId])
  @@index([entityType, entityUuid])
  @@map("changelog")
  @@schema("meta")
}

enum UserRole {
  user
  admin

  @@schema("meta")
}

model User {
  id           Int      @id @default(autoincrement())
  uuid         String   @unique @default(cuid()) @db.VarChar(36)
  email        String   @unique @db.VarChar(255)
  username     String   @unique @db.VarChar(50)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         UserRole @default(user)
  avatarUrl    String?  @map("avatar_url") @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([email])
  @@map("users")
  @@schema("meta")
}

// ╔══════════════════════════════════════════════════════════════╗
// ║  RSI SCHEMA — RSI website + SC Wiki scraped data             ║
// ╚══════════════════════════════════════════════════════════════╝

model ShipMatrix {
  id                Int      @id
  name              String   @db.VarChar(255)
  chassisId         Int?     @map("chassis_id")
  manufacturerCode  String?  @map("manufacturer_code") @db.VarChar(10)
  manufacturerName  String?  @map("manufacturer_name") @db.VarChar(100)
  focus             String?  @db.VarChar(255)
  type              String?  @db.VarChar(50)
  description       String?
  productionStatus  String?  @map("production_status") @db.VarChar(50)
  productionNote    String?  @map("production_note")
  size              String?  @db.VarChar(20)
  url               String?  @db.VarChar(500)
  length            Decimal? @db.Decimal(10, 2)
  beam              Decimal? @db.Decimal(10, 2)
  height            Decimal? @db.Decimal(10, 2)
  mass              Int?
  cargocapacity     Int?
  minCrew           Int?     @default(1) @map("min_crew")
  maxCrew           Int?     @default(1) @map("max_crew")
  scmSpeed          Int?     @map("scm_speed")
  afterburnerSpeed  Int?     @map("afterburner_speed")
  pitchMax          Decimal? @map("pitch_max") @db.Decimal(10, 2)
  yawMax            Decimal? @map("yaw_max") @db.Decimal(10, 2)
  rollMax           Decimal? @map("roll_max") @db.Decimal(10, 2)
  xaxisAcceleration Decimal? @map("xaxis_acceleration") @db.Decimal(10, 4)
  yaxisAcceleration Decimal? @map("yaxis_acceleration") @db.Decimal(10, 4)
  zaxisAcceleration Decimal? @map("zaxis_acceleration") @db.Decimal(10, 4)
  mediaSourceUrl    String?  @map("media_source_url")
  mediaStoreSmall   String?  @map("media_store_small")
  mediaStoreLarge   String?  @map("media_store_large")
  compiled          Json?
  syncedAt          DateTime @default(now()) @map("synced_at")

  @@map("ship_matrix")
  @@schema("rsi")
}

model Galactapedia {
  id           String   @id @db.VarChar(50)
  slug         String   @db.VarChar(255)
  title        String   @db.VarChar(500)
  content      String?
  excerpt      String?  @db.VarChar(500)
  categories   Json?
  tags         Json?
  thumbnailUrl String?  @map("thumbnail_url") @db.VarChar(500)
  rsiUrl       String?  @map("rsi_url") @db.VarChar(500)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([slug])
  @@map("galactapedia")
  @@schema("rsi")
}

model CommLink {
  id           Int       @id @default(autoincrement())
  rsiId        String    @unique @map("rsi_id") @db.VarChar(20)
  slug         String?   @db.VarChar(255)
  title        String    @db.VarChar(500)
  content      String?
  excerpt      String?   @db.VarChar(500)
  category     String?   @db.VarChar(100)
  thumbnailUrl String?   @map("thumbnail_url") @db.VarChar(500)
  rsiUrl       String?   @map("rsi_url") @db.VarChar(500)
  publishedAt  DateTime? @map("published_at")

  @@index([category])
  @@index([publishedAt])
  @@map("comm_links")
  @@schema("rsi")
}

model StarmapLocation {
  id           Int      @id @default(autoincrement())
  rsiId        String   @unique @map("rsi_id") @db.VarChar(50)
  name         String   @db.VarChar(255)
  type         String   @db.VarChar(50)
  systemCode   String?  @map("system_code") @db.VarChar(20)
  systemName   String?  @map("system_name") @db.VarChar(255)
  parentId     String?  @map("parent_id") @db.VarChar(50)
  factionName  String?  @map("faction_name") @db.VarChar(100)
  affiliations Json?
  thumbnail    String?  @db.VarChar(500)
  description  String?
  coordinates  Json?
  jumpPoints   Json?    @map("jump_points")
  syncedAt     DateTime @default(now()) @map("synced_at")

  @@index([systemCode])
  @@index([type])
  @@map("starmap_locations")
  @@schema("rsi")
}

// ╔══════════════════════════════════════════════════════════════╗
// ║  GAME SCHEMA — P4K extracted data, live + ptu via env field  ║
// ╚══════════════════════════════════════════════════════════════╝
//
//  All models have env String @default("live").
//  UUID-keyed tables use @@id([uuid, env]).
//  Int-id tables keep autoincrement PK and add env + unique constraints.

// ─── Manufacturers ────────────────────────────────────────────────────────────

model Manufacturer {
  code       String  @id @db.VarChar(20)
  name       String  @db.VarChar(100)
  knownFor   String? @map("known_for") @db.VarChar(255)
  logoUrl    String? @map("logo_url") @db.VarChar(500)
  websiteUrl String? @map("website_url") @db.VarChar(500)

  @@map("manufacturers")
  @@schema("game")
}

// ─── Ships ────────────────────────────────────────────────────────────────────

model Ship {
  uuid                  String   @db.Char(36)
  env                   String   @default("live") @db.VarChar(10)
  className             String   @map("class_name") @db.VarChar(255)
  name                  String?  @db.VarChar(255)
  manufacturerCode      String?  @map("manufacturer_code") @db.VarChar(10)
  role                  String?  @db.VarChar(100)
  career                String?  @db.VarChar(100)
  crewSize              Int?     @default(1) @map("crew_size")
  sizeX                 Decimal? @map("size_x") @db.Decimal(10, 2)
  sizeY                 Decimal? @map("size_y") @db.Decimal(10, 2)
  sizeZ                 Decimal? @map("size_z") @db.Decimal(10, 2)
  mass                  Decimal? @db.Decimal(15, 2)
  scmSpeed              Int?     @map("scm_speed")
  maxSpeed              Int?     @map("max_speed")
  boostSpeedForward     Int?     @map("boost_speed_forward")
  boostSpeedBackward    Int?     @map("boost_speed_backward")
  pitchMax              Decimal? @map("pitch_max") @db.Decimal(8, 2)
  yawMax                Decimal? @map("yaw_max") @db.Decimal(8, 2)
  rollMax               Decimal? @map("roll_max") @db.Decimal(8, 2)
  totalHp               Int?     @map("total_hp")
  hydrogenFuelCapacity  Decimal? @map("hydrogen_fuel_capacity") @db.Decimal(10, 2)
  quantumFuelCapacity   Decimal? @map("quantum_fuel_capacity") @db.Decimal(10, 2)
  shieldHp              Int?     @map("shield_hp")
  shieldRegen           Decimal? @map("shield_regen") @db.Decimal(10, 4)
  shieldRegenDelay      Decimal? @map("shield_regen_delay") @db.Decimal(10, 2)
  shieldDownDelay       Decimal? @map("shield_down_delay") @db.Decimal(10, 2)
  armorPhysical         Decimal? @map("armor_physical") @db.Decimal(10, 6)
  armorEnergy           Decimal? @map("armor_energy") @db.Decimal(10, 6)
  armorDistortion       Decimal? @map("armor_distortion") @db.Decimal(10, 6)
  armorThermal          Decimal? @map("armor_thermal") @db.Decimal(10, 6)
  armorSignalIr         Decimal? @map("armor_signal_ir") @db.Decimal(10, 6)
  armorSignalEm         Decimal? @map("armor_signal_em") @db.Decimal(10, 6)
  armorSignalCs         Decimal? @map("armor_signal_cs") @db.Decimal(10, 6)
  armorHp               Decimal? @map("armor_hp") @db.Decimal(10, 2)
  armorPhysResist       Decimal? @map("armor_phys_resist") @db.Decimal(10, 6)
  armorEnergyResist     Decimal? @map("armor_energy_resist") @db.Decimal(10, 6)
  fusePenetration       Decimal? @map("fuse_penetration") @db.Decimal(10, 4)
  componentPenetration  Decimal? @map("component_penetration") @db.Decimal(10, 4)
  boostRampUp           Decimal? @map("boost_ramp_up") @db.Decimal(8, 2)
  boostRampDown         Decimal? @map("boost_ramp_down") @db.Decimal(8, 2)
  crossSectionX         Decimal? @map("cross_section_x") @db.Decimal(10, 2)
  crossSectionY         Decimal? @map("cross_section_y") @db.Decimal(10, 2)
  crossSectionZ         Decimal? @map("cross_section_z") @db.Decimal(10, 2)
  shortName             String?  @map("short_name") @db.VarChar(255)
  cargoCapacity         Decimal? @map("cargo_capacity") @db.Decimal(10, 2)
  missileDamageTotal    Decimal? @map("missile_damage_total") @db.Decimal(10, 2)
  weaponDamageTotal     Decimal? @map("weapon_damage_total") @db.Decimal(10, 2)
  variantType           String?  @map("variant_type") @db.VarChar(20)
  vehicleCategory       String?  @default("ship") @map("vehicle_category") @db.VarChar(20)
  chassisId             Int?     @map("chassis_id")
  insuranceClaimTime    Decimal? @map("insurance_claim_time") @db.Decimal(10, 2)
  insuranceExpediteCost Decimal? @map("insurance_expedite_cost") @db.Decimal(10, 2)
  gameData              Json?    @map("game_data")
  /// FK to rsi.ship_matrix (cross-schema — now a real constraint in PostgreSQL)
  shipMatrixId          Int?     @map("ship_matrix_id")
  ctmUrl                String?  @map("ctm_url") @db.VarChar(500)
  extractedAt           DateTime @default(now()) @map("extracted_at")

  loadouts ShipLoadout[]
  modules  ShipModule[]
  paints   ShipPaint[]

  @@id([uuid, env])
  @@unique([className, env])
  @@index([manufacturerCode])
  @@index([shipMatrixId])
  @@index([chassisId])
  @@index([env])
  @@map("ships")
  @@schema("game")
}

model ShipLoadout {
  id                 Int     @id @default(autoincrement())
  shipUuid           String  @map("ship_uuid") @db.Char(36)
  env                String  @default("live") @db.VarChar(10)
  portName           String  @map("port_name") @db.VarChar(100)
  portMinSize        Int?    @map("port_min_size")
  portMaxSize        Int?    @map("port_max_size")
  portEditable       Boolean @default(true) @map("port_editable")
  componentClassName String? @map("component_class_name") @db.VarChar(255)
  componentUuid      String? @map("component_uuid") @db.Char(36)
  portType           String? @map("port_type") @db.VarChar(50)
  parentId           Int?    @map("parent_id")

  ship Ship @relation(fields: [shipUuid, env], references: [uuid, env], onDelete: Cascade)

  @@index([shipUuid, env])
  @@index([componentUuid])
  @@map("ship_loadouts")
  @@schema("game")
}

model ShipModule {
  id              Int     @id @default(autoincrement())
  shipUuid        String  @map("ship_uuid") @db.Char(36)
  env             String  @default("live") @db.VarChar(10)
  slotName        String  @map("slot_name") @db.VarChar(100)
  slotDisplayName String? @map("slot_display_name") @db.VarChar(100)
  slotType        String? @map("slot_type") @db.VarChar(20)
  moduleClassName String  @map("module_class_name") @db.VarChar(255)
  moduleName      String? @map("module_name") @db.VarChar(255)
  moduleTier      Int?    @map("module_tier")
  isDefault       Boolean @default(false) @map("is_default")
  loadoutJson     Json?   @map("loadout_json")

  ship Ship @relation(fields: [shipUuid, env], references: [uuid, env], onDelete: Cascade)

  @@index([shipUuid, env])
  @@map("ship_modules")
  @@schema("game")
}

model ShipPaint {
  id             Int     @id @default(autoincrement())
  shipUuid       String  @map("ship_uuid") @db.Char(36)
  env            String  @default("live") @db.VarChar(10)
  paintClassName String  @map("paint_class_name") @db.VarChar(255)
  paintName      String? @map("paint_name") @db.VarChar(255)
  paintUuid      String? @map("paint_uuid") @db.Char(36)

  ship Ship @relation(fields: [shipUuid, env], references: [uuid, env], onDelete: Cascade)

  @@index([shipUuid, env])
  @@map("ship_paints")
  @@schema("game")
}

// ─── Components ───────────────────────────────────────────────────────────────

model Component {
  uuid                    String   @db.Char(36)
  env                     String   @default("live") @db.VarChar(10)
  className               String   @map("class_name") @db.VarChar(255)
  name                    String   @db.VarChar(255)
  normalizedName          String?  @map("normalized_name") @db.VarChar(255)
  canonicalComponentKey   String?  @map("canonical_component_key") @db.VarChar(255)
  type                    String   @db.VarChar(50)
  subType                 String?  @map("sub_type") @db.VarChar(100)
  size                    Int?
  grade                   String?  @db.VarChar(10)
  manufacturerCode        String?  @map("manufacturer_code") @db.VarChar(10)
  mass                    Decimal? @db.Decimal(10, 2)
  hp                      Int?
  powerDraw               Decimal? @map("power_draw") @db.Decimal(10, 2)
  powerBase               Decimal? @map("power_base") @db.Decimal(10, 2)
  powerOutput             Decimal? @map("power_output") @db.Decimal(10, 2)
  heatGeneration          Decimal? @map("heat_generation") @db.Decimal(10, 2)
  coolingRate             Decimal? @map("cooling_rate") @db.Decimal(15, 2)
  emSignature             Decimal? @map("em_signature") @db.Decimal(10, 2)
  irSignature             Decimal? @map("ir_signature") @db.Decimal(10, 2)
  weaponDamage            Decimal? @map("weapon_damage") @db.Decimal(10, 4)
  weaponDamageType        String?  @map("weapon_damage_type") @db.VarChar(50)
  weaponFireRate          Decimal? @map("weapon_fire_rate") @db.Decimal(10, 4)
  weaponRange             Decimal? @map("weapon_range") @db.Decimal(10, 2)
  weaponSpeed             Decimal? @map("weapon_speed") @db.Decimal(10, 2)
  weaponAmmoCount         Int?     @map("weapon_ammo_count")
  weaponPelletsPerShot    Int?     @default(1) @map("weapon_pellets_per_shot")
  weaponBurstSize         Int?     @map("weapon_burst_size")
  weaponAlphaDamage       Decimal? @map("weapon_alpha_damage") @db.Decimal(10, 4)
  weaponDps               Decimal? @map("weapon_dps") @db.Decimal(10, 4)
  weaponDamagePhysical     Decimal? @map("weapon_damage_physical") @db.Decimal(10, 4)
  weaponDamageEnergy       Decimal? @map("weapon_damage_energy") @db.Decimal(10, 4)
  weaponDamageDistortion   Decimal? @map("weapon_damage_distortion") @db.Decimal(10, 4)
  weaponDamageThermal      Decimal? @map("weapon_damage_thermal") @db.Decimal(10, 4)
  weaponDamageBiochemical  Decimal? @map("weapon_damage_biochemical") @db.Decimal(10, 4)
  weaponDamageStun         Decimal? @map("weapon_damage_stun") @db.Decimal(10, 4)
  weaponBurstDps           Decimal? @map("weapon_burst_dps") @db.Decimal(10, 4)
  weaponSustainedDps       Decimal? @map("weapon_sustained_dps") @db.Decimal(10, 4)
  weaponFullDamageRange    Decimal? @map("weapon_full_damage_range") @db.Decimal(10, 2)
  weaponZeroDamageRange    Decimal? @map("weapon_zero_damage_range") @db.Decimal(10, 2)
  weaponHeatPerSecond      Decimal? @map("weapon_heat_per_second") @db.Decimal(10, 4)
  weaponBeamCapacity       Decimal? @map("weapon_beam_capacity") @db.Decimal(10, 2)
  weaponBeamRegenCooldown  Decimal? @map("weapon_beam_regen_cooldown") @db.Decimal(10, 2)
  weaponBeamDps            Decimal? @map("weapon_beam_dps") @db.Decimal(10, 4)
  shieldHp                Decimal? @map("shield_hp") @db.Decimal(15, 2)
  shieldRegen             Decimal? @map("shield_regen") @db.Decimal(10, 4)
  shieldRegenDelay        Decimal? @map("shield_regen_delay") @db.Decimal(10, 2)
  shieldHardening         Decimal? @map("shield_hardening") @db.Decimal(10, 4)
  shieldFaces             Int?     @map("shield_faces")
  qdSpeed                 Decimal? @map("qd_speed") @db.Decimal(15, 2)
  qdSpoolTime             Decimal? @map("qd_spool_time") @db.Decimal(10, 2)
  qdCooldown              Decimal? @map("qd_cooldown") @db.Decimal(10, 2)
  qdFuelRate              Decimal? @map("qd_fuel_rate") @db.Decimal(10, 6)
  qdRange                 Decimal? @map("qd_range") @db.Decimal(15, 2)
  qdStage1Accel           Decimal? @map("qd_stage1_accel") @db.Decimal(15, 2)
  qdStage2Accel           Decimal? @map("qd_stage2_accel") @db.Decimal(15, 2)
  qdTuningRate            Decimal? @map("qd_tuning_rate") @db.Decimal(10, 4)
  qdAlignmentRate         Decimal? @map("qd_alignment_rate") @db.Decimal(10, 4)
  qdDisconnectRange       Decimal? @map("qd_disconnect_range") @db.Decimal(15, 2)
  missileDamage           Decimal? @map("missile_damage") @db.Decimal(10, 2)
  missileSignalType       String?  @map("missile_signal_type") @db.VarChar(20)
  missileLockTime         Decimal? @map("missile_lock_time") @db.Decimal(10, 2)
  missileSpeed            Decimal? @map("missile_speed") @db.Decimal(10, 2)
  missileRange            Decimal? @map("missile_range") @db.Decimal(10, 2)
  missileLockRange        Decimal? @map("missile_lock_range") @db.Decimal(10, 2)
  missileDamagePhysical    Decimal? @map("missile_damage_physical") @db.Decimal(10, 2)
  missileDamageEnergy      Decimal? @map("missile_damage_energy") @db.Decimal(10, 2)
  missileDamageDistortion  Decimal? @map("missile_damage_distortion") @db.Decimal(10, 2)
  missileDamageThermal     Decimal? @map("missile_damage_thermal") @db.Decimal(10, 2)
  missileDamageBiochemical Decimal? @map("missile_damage_biochemical") @db.Decimal(10, 2)
  missileDamageStun        Decimal? @map("missile_damage_stun") @db.Decimal(10, 2)
  thrusterMaxThrust       Decimal? @map("thruster_max_thrust") @db.Decimal(15, 2)
  thrusterType            String?  @map("thruster_type") @db.VarChar(50)
  radarRange              Decimal? @map("radar_range") @db.Decimal(15, 2)
  radarDetectionLifetime  Decimal? @map("radar_detection_lifetime") @db.Decimal(10, 2)
  radarTrackingSignal     Decimal? @map("radar_tracking_signal") @db.Decimal(10, 4)
  cmAmmoCount             Int?     @map("cm_ammo_count")
  fuelCapacity            Decimal? @map("fuel_capacity") @db.Decimal(10, 2)
  fuelIntakeRate          Decimal? @map("fuel_intake_rate") @db.Decimal(10, 4)
  empDamage               Decimal? @map("emp_damage") @db.Decimal(10, 2)
  empRadius               Decimal? @map("emp_radius") @db.Decimal(10, 2)
  empChargeTime           Decimal? @map("emp_charge_time") @db.Decimal(10, 2)
  empCooldown             Decimal? @map("emp_cooldown") @db.Decimal(10, 2)
  qigJammerRange          Decimal? @map("qig_jammer_range") @db.Decimal(15, 2)
  qigSnareRadius          Decimal? @map("qig_snare_radius") @db.Decimal(15, 2)
  qigChargeTime           Decimal? @map("qig_charge_time") @db.Decimal(10, 2)
  qigCooldown             Decimal? @map("qig_cooldown") @db.Decimal(10, 2)
  miningSpeed             Decimal? @map("mining_speed") @db.Decimal(10, 4)
  miningRange             Decimal? @map("mining_range") @db.Decimal(10, 2)
  miningResistance        Decimal? @map("mining_resistance") @db.Decimal(10, 4)
  miningInstability       Decimal? @map("mining_instability") @db.Decimal(10, 4)
  tractorMaxForce         Decimal? @map("tractor_max_force") @db.Decimal(15, 2)
  tractorMaxRange         Decimal? @map("tractor_max_range") @db.Decimal(10, 2)
  salvageSpeed            Decimal? @map("salvage_speed") @db.Decimal(10, 4)
  salvageRadius           Decimal? @map("salvage_radius") @db.Decimal(10, 2)
  gimbalType              String?  @map("gimbal_type") @db.VarChar(20)
  rackCount               Int?     @map("rack_count")
  rackMissileSize         Int?     @map("rack_missile_size")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @default(now()) @updatedAt @map("updated_at")

  @@id([uuid, env])
  @@unique([className, env])
  @@index([manufacturerCode])
  @@index([type])
  @@index([subType])
  @@index([canonicalComponentKey])
  @@index([env])
  @@map("components")
  @@schema("game")
}

// ─── Items ────────────────────────────────────────────────────────────────────

model Item {
  uuid             String   @db.Char(36)
  env              String   @default("live") @db.VarChar(10)
  className        String   @map("class_name") @db.VarChar(255)
  name             String   @db.VarChar(255)
  normalizedName   String?  @map("normalized_name") @db.VarChar(255)
  canonicalItemKey String?  @map("canonical_item_key") @db.VarChar(255)
  type             String   @db.VarChar(50)
  subType          String?  @map("sub_type") @db.VarChar(100)
  size             Int?
  grade            String?  @db.VarChar(10)
  manufacturerCode String?  @map("manufacturer_code") @db.VarChar(10)
  mass             Decimal? @db.Decimal(10, 2)
  hp               Int?
  weaponDamage         Decimal? @map("weapon_damage") @db.Decimal(10, 4)
  weaponDamageType     String?  @map("weapon_damage_type") @db.VarChar(50)
  weaponFireRate       Decimal? @map("weapon_fire_rate") @db.Decimal(10, 4)
  weaponRange          Decimal? @map("weapon_range") @db.Decimal(10, 2)
  weaponSpeed          Decimal? @map("weapon_speed") @db.Decimal(10, 2)
  weaponAmmoCount      Int?     @map("weapon_ammo_count")
  weaponDps            Decimal? @map("weapon_dps") @db.Decimal(10, 4)
  armorDamageReduction Decimal? @map("armor_damage_reduction") @db.Decimal(10, 4)
  armorTempMin         Decimal? @map("armor_temp_min") @db.Decimal(10, 2)
  armorTempMax         Decimal? @map("armor_temp_max") @db.Decimal(10, 2)
  dataJson             Json?    @map("data_json")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at")

  @@id([uuid, env])
  @@unique([className, env])
  @@index([canonicalItemKey])
  @@index([manufacturerCode])
  @@index([env])
  @@map("items")
  @@schema("game")
}

// ─── Commodities ──────────────────────────────────────────────────────────────

model Commodity {
  uuid                  String   @db.Char(36)
  env                   String   @default("live") @db.VarChar(10)
  className             String   @map("class_name") @db.VarChar(255)
  name                  String   @db.VarChar(255)
  normalizedName        String?  @map("normalized_name") @db.VarChar(255)
  canonicalCommodityKey String?  @map("canonical_commodity_key") @db.VarChar(255)
  type                  String   @db.VarChar(50)
  subType               String?  @map("sub_type") @db.VarChar(100)
  symbol                String?  @db.VarChar(20)
  occupancyScu          Decimal? @map("occupancy_scu") @db.Decimal(10, 4)
  dataJson              Json?    @map("data_json")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")

  prices CommodityPrice[]

  @@id([uuid, env])
  @@unique([className, env])
  @@index([canonicalCommodityKey])
  @@index([env])
  @@map("commodities")
  @@schema("game")
}

// ─── Shops & trade ────────────────────────────────────────────────────────────

model Shop {
  id                   Int      @id @default(autoincrement())
  env                  String   @default("live") @db.VarChar(10)
  name                 String   @db.VarChar(255)
  className            String   @map("class_name") @db.VarChar(255)
  normalizedName       String?  @map("normalized_name") @db.VarChar(255)
  canonicalShopKey     String?  @map("canonical_shop_key") @db.VarChar(255)
  canonicalLocationKey String?  @map("canonical_location_key") @db.VarChar(255)
  location             String?  @db.VarChar(255)
  system               String?  @db.VarChar(50)
  planetMoon           String?  @map("planet_moon") @db.VarChar(100)
  city                 String?  @db.VarChar(100)
  shopType             String?  @map("shop_type") @db.VarChar(50)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at")

  inventory       ShopInventory[]
  commodityPrices CommodityPrice[]

  @@unique([className, env])
  @@index([canonicalShopKey])
  @@index([canonicalLocationKey])
  @@index([env])
  @@map("shops")
  @@schema("game")
}

model ShopInventory {
  id                 Int      @id @default(autoincrement())
  shopId             Int      @map("shop_id")
  componentUuid      String?  @map("component_uuid") @db.Char(36)
  componentClassName String   @map("component_class_name") @db.VarChar(255)
  basePrice          Decimal? @map("base_price") @db.Decimal(12, 2)
  rentalPrice1d      Decimal? @map("rental_price_1d") @db.Decimal(12, 2)
  rentalPrice3d      Decimal? @map("rental_price_3d") @db.Decimal(12, 2)
  rentalPrice7d      Decimal? @map("rental_price_7d") @db.Decimal(12, 2)
  rentalPrice30d     Decimal? @map("rental_price_30d") @db.Decimal(12, 2)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, componentClassName])
  @@index([shopId])
  @@index([componentUuid])
  @@map("shop_inventory")
  @@schema("game")
}

model CommodityPrice {
  id            Int      @id @default(autoincrement())
  commodityUuid String   @map("commodity_uuid") @db.Char(36)
  commodityEnv  String   @default("live") @map("commodity_env") @db.VarChar(10)
  shopId        Int      @map("shop_id")
  buyPrice      Decimal? @map("buy_price") @db.Decimal(12, 2)
  sellPrice     Decimal? @map("sell_price") @db.Decimal(12, 2)
  reportedAt    DateTime @default(now()) @map("reported_at")

  commodity Commodity @relation(fields: [commodityUuid, commodityEnv], references: [uuid, env], onDelete: Cascade)
  shop      Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([commodityUuid, shopId])
  @@index([shopId])
  @@index([commodityUuid])
  @@map("commodity_prices")
  @@schema("game")
}

// ─── Mining ───────────────────────────────────────────────────────────────────

model MiningElement {
  uuid                      String   @db.Char(36)
  env                       String   @default("live") @db.VarChar(10)
  className                 String   @map("class_name") @db.VarChar(255)
  name                      String?  @db.VarChar(255)
  commodityUuid             String?  @map("commodity_uuid") @db.Char(36)
  instability               Decimal? @db.Decimal(8, 2)
  resistance                Decimal? @db.Decimal(6, 4)
  optimalWindowMidpoint     Decimal? @map("optimal_window_midpoint") @db.Decimal(6, 4)
  optimalWindowMidpointRand Decimal? @map("optimal_window_midpoint_rand") @db.Decimal(6, 4)
  optimalWindowThinness     Decimal? @map("optimal_window_thinness") @db.Decimal(6, 4)
  explosionMultiplier       Decimal? @map("explosion_multiplier") @db.Decimal(8, 2)
  clusterFactor             Decimal? @map("cluster_factor") @db.Decimal(6, 4)

  compositionParts MiningCompositionPart[]

  @@id([uuid, env])
  @@unique([className, env])
  @@index([env])
  @@map("mining_elements")
  @@schema("game")
}

model MiningComposition {
  uuid                String  @db.Char(36)
  env                 String  @default("live") @db.VarChar(10)
  className           String  @map("class_name") @db.VarChar(255)
  depositName         String? @map("deposit_name") @db.VarChar(255)
  minDistinctElements Int?    @map("min_distinct_elements")

  parts MiningCompositionPart[]

  @@id([uuid, env])
  @@unique([className, env])
  @@index([env])
  @@map("mining_compositions")
  @@schema("game")
}

model MiningCompositionPart {
  id              Int      @id @default(autoincrement())
  compositionUuid String   @map("composition_uuid") @db.Char(36)
  compositionEnv  String   @default("live") @map("composition_env") @db.VarChar(10)
  elementUuid     String   @map("element_uuid") @db.Char(36)
  elementEnv      String   @default("live") @map("element_env") @db.VarChar(10)
  minPercentage   Decimal? @map("min_percentage") @db.Decimal(6, 2)
  maxPercentage   Decimal? @map("max_percentage") @db.Decimal(6, 2)
  probability     Decimal? @db.Decimal(6, 4)
  curveExponent   Decimal? @map("curve_exponent") @db.Decimal(6, 4)

  composition MiningComposition @relation(fields: [compositionUuid, compositionEnv], references: [uuid, env], onDelete: Cascade)
  element     MiningElement     @relation(fields: [elementUuid, elementEnv], references: [uuid, env], onDelete: Cascade)

  @@index([compositionUuid, compositionEnv])
  @@index([elementUuid, elementEnv])
  @@map("mining_composition_parts")
  @@schema("game")
}

// ─── Missions ─────────────────────────────────────────────────────────────────

model Mission {
  uuid               String  @db.Char(36)
  env                String  @default("live") @db.VarChar(10)
  className          String  @map("class_name") @db.VarChar(300)
  title              String? @db.VarChar(500)
  description        String?
  missionType        String? @map("mission_type") @db.VarChar(100)
  canBeShared        Boolean @default(false) @map("can_be_shared")
  onlyOwnerComplete  Boolean @default(false) @map("only_owner_complete")
  isLegal            Boolean @default(true) @map("is_legal")
  completionTimeSecs Int?    @map("completion_time_s")
  notForRelease      Boolean @default(false) @map("not_for_release")
  workInProgress     Boolean @default(false) @map("work_in_progress")
  rewardMin          Int?    @map("reward_min")
  rewardMax          Int?    @map("reward_max")
  rewardCurrency     String? @map("reward_currency") @db.VarChar(20)
  faction            String? @db.VarChar(100)
  missionGiver       String? @map("mission_giver") @db.VarChar(200)
  locationSystem     String? @map("location_system") @db.VarChar(100)
  locationPlanet     String? @map("location_planet") @db.VarChar(100)
  locationName       String? @map("location_name") @db.VarChar(200)
  dangerLevel        Int?    @map("danger_level")
  requiredReputation Int?    @map("required_reputation")
  reputationReward   Int?    @map("reputation_reward")
  buyInAmount        Int?    @map("buy_in_amount")
  baseXp             Int?    @map("base_xp")
  category           String? @db.VarChar(50)
  isUnique           Boolean @default(false) @map("is_unique")
  hasBlueprintReward Boolean @default(false) @map("has_blueprint_reward")
  blueprintRewardUuid String? @map("blueprint_reward_uuid") @db.Char(36)
  blueprintRewardEnv  String? @default("live") @map("blueprint_reward_env") @db.VarChar(10)

  blueprint        CraftingRecipe?         @relation("MissionLegacyBlueprint", fields: [blueprintRewardUuid, blueprintRewardEnv], references: [uuid, env])
  blueprintRewards MissionBlueprintReward[]

  @@id([uuid, env])
  @@unique([className, env])
  @@index([missionType])
  @@index([faction])
  @@index([locationSystem])
  @@index([category])
  @@index([env])
  @@map("missions")
  @@schema("game")
}

// ─── Crafting ─────────────────────────────────────────────────────────────────

model CraftingRecipe {
  uuid           String   @db.Char(36)
  env            String   @default("live") @db.VarChar(10)
  className      String   @map("class_name") @db.VarChar(255)
  name           String?  @db.VarChar(255)
  category       String?  @db.VarChar(50)
  outputItemName String?  @map("output_item_name") @db.VarChar(255)
  outputItemUuid String?  @map("output_item_uuid") @db.Char(36)
  outputQuantity Int      @default(1) @map("output_quantity")
  craftingTime   Int?     @map("crafting_time_s")
  stationType    String?  @map("station_type") @db.VarChar(100)
  skillLevel     Int?     @map("skill_level")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  ingredients    CraftingIngredient[]
  modifiers      CraftingSlotModifier[]
  missions       Mission[]              @relation("MissionLegacyBlueprint")
  missionRewards MissionBlueprintReward[]

  @@id([uuid, env])
  @@unique([className, env])
  @@index([category])
  @@index([env])
  @@map("crafting_recipes")
  @@schema("game")
}

model MissionBlueprintReward {
  id             Int    @id @default(autoincrement())
  missionUuid    String @map("mission_uuid") @db.Char(36)
  missionEnv     String @default("live") @map("mission_env") @db.VarChar(10)
  blueprintUuid  String @map("blueprint_uuid") @db.Char(36)
  blueprintEnv   String @default("live") @map("blueprint_env") @db.VarChar(10)

  mission   Mission        @relation(fields: [missionUuid, missionEnv], references: [uuid, env], onDelete: Cascade)
  blueprint CraftingRecipe @relation(fields: [blueprintUuid, blueprintEnv], references: [uuid, env], onDelete: Cascade)

  @@unique([missionUuid, blueprintUuid])
  @@index([blueprintUuid])
  @@map("mission_blueprint_rewards")
  @@schema("game")
}

model CraftingIngredient {
  id         Int      @id @default(autoincrement())
  recipeUuid String   @map("recipe_uuid") @db.Char(36)
  recipeEnv  String   @default("live") @map("recipe_env") @db.VarChar(10)
  itemName   String   @map("item_name") @db.VarChar(255)
  itemUuid   String?  @map("item_uuid") @db.Char(36)
  quantity   Int      @default(1)
  isOptional Boolean  @default(false) @map("is_optional")
  scu        Decimal? @db.Decimal(10, 4)
  minQuality Int      @default(0) @map("min_quality")
  slotName   String?  @map("slot_name") @db.VarChar(255)

  recipe CraftingRecipe @relation(fields: [recipeUuid, recipeEnv], references: [uuid, env], onDelete: Cascade)

  @@index([recipeUuid, recipeEnv])
  @@map("crafting_ingredients")
  @@schema("game")
}

model CraftingSlotModifier {
  id              Int     @id @default(autoincrement())
  recipeUuid      String  @map("recipe_uuid") @db.Char(36)
  recipeEnv       String  @default("live") @map("recipe_env") @db.VarChar(10)
  slotName        String  @map("slot_name") @db.VarChar(255)
  propertyName    String  @map("property_name") @db.VarChar(255)
  propertyUuid    String  @map("property_uuid") @db.Char(36)
  unitFormat      String  @default("") @map("unit_format") @db.VarChar(100)
  startQuality    Int     @default(0) @map("start_quality")
  endQuality      Int     @default(1000) @map("end_quality")
  modifierAtStart Decimal  @map("modifier_at_start") @db.Decimal(10, 6)
  modifierAtEnd   Decimal  @map("modifier_at_end") @db.Decimal(10, 6)
  modifierType    String?  @map("modifier_type") @db.VarChar(100)

  recipe CraftingRecipe @relation(fields: [recipeUuid, recipeEnv], references: [uuid, env], onDelete: Cascade)

  @@index([recipeUuid, recipeEnv])
  @@map("crafting_slot_modifiers")
  @@schema("game")
}

// ─── Locations ────────────────────────────────────────────────────────────────

model Location {
  uuid          String   @db.Char(36)
  env           String   @default("live") @db.VarChar(10)
  className     String   @map("class_name") @db.VarChar(255)
  name          String   @db.VarChar(255)
  type          String   @db.VarChar(50)
  systemCode    String?  @map("system_code") @db.VarChar(20)
  parentUuid    String?  @map("parent_uuid") @db.Char(36)
  locKey        String?  @map("loc_key") @db.VarChar(255)
  description   String?
  isScannable   Boolean  @default(false) @map("is_scannable")
  hideInStarmap Boolean  @default(false) @map("hide_in_starmap")
  extractedAt   DateTime @default(now()) @map("extracted_at")

  @@id([uuid, env])
  @@unique([className, env])
  @@index([type])
  @@index([systemCode])
  @@index([parentUuid])
  @@index([env])
  @@map("locations")
  @@schema("game")
}
