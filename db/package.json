{
  "name": "@starvis/db",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "generate": "npm run generate:game && npm run generate:starvis && npm run generate:rsi",
    "generate:game": "prisma generate --schema=prisma/game.prisma",
    "generate:starvis": "prisma generate --schema=prisma/starvis.prisma",
    "generate:rsi": "prisma generate --schema=prisma/rsi.prisma",
    "push": "npm run push:game && npm run push:starvis && npm run push:rsi",
    "push:game": "prisma db push --schema=prisma/game.prisma",
    "push:starvis": "prisma db push --schema=prisma/starvis.prisma",
    "push:rsi": "prisma db push --schema=prisma/rsi.prisma",
    "studio:game": "prisma studio --schema=prisma/game.prisma",
    "studio:starvis": "prisma studio --schema=prisma/starvis.prisma",
    "studio:rsi": "prisma studio --schema=prisma/rsi.prisma",
    "postinstall": "npm run generate"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0"
  },
  "type": "module"
}
