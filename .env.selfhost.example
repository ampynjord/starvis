# ============================================================
# STARVIS — Configuration self-hosted
# Copier ce fichier en .env.selfhost et remplir les valeurs
# NE PAS committer .env.selfhost
# ============================================================

# --- Sécurité (obligatoires) ---
DB_PASSWORD=changeme
JWT_SECRET=changeme_jwt_secret_32chars_minimum
ADMIN_API_KEY=changeme_admin_key

# --- Base de données ---
DB_NAME=starvis
DB_USER=starvis_user

# --- Ports exposés ---
# IHM accessible sur http://localhost:8080 par défaut
IHM_PORT=8080
# API accessible sur 127.0.0.1:3000 uniquement (loopback)
# Changer en 0.0.0.0:3000 pour exposer sur le réseau
API_PORT=127.0.0.1:3000

# --- IHM ---
# Désactiver l'authentification (tout le monde peut accéder)
INSPECTION_MODE=false

# --- API ---
CORS_ORIGIN=*
LOG_LEVEL=info
RATE_LIMIT_MAX=500
RATE_LIMIT_BURST=50
# MISTRAL_API_KEY=       # Optionnel — pour les features IA

# --- Discord bot (optionnel) ---
# Laisser vide pour désactiver le bot
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
API_TOKEN=
# URL publique de l'IHM affichée dans les embeds Discord
SITE_URL=http://localhost:8080

# --- Images (laisser vide pour utiliser les dernières versions) ---
# API_IMAGE=ghcr.io/ampynjord/starvis-api:1.0.0
# IHM_IMAGE=ghcr.io/ampynjord/starvis-ihm:1.0.0
# BOT_IMAGE=ghcr.io/ampynjord/starvis-bot:1.0.0

# --- Ressources ---
REDIS_MAXMEMORY=64mb
