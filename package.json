{
  "name": "starvis-monorepo",
  "private": true,
  "license": "UNLICENSED",
  "workspaces": [
    "api",
    "ihm",
    "extractor",
    "bot",
    "db",
    "extensions/rsi-hangar-sync"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:ci": "npm exec -- biome ci .github README.md LICENSE package.json package-lock.json biome.json api bot db extractor ihm extensions quality",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "npm run generate --workspace=@starvis/db",
    "db:push": "npm run push --workspace=@starvis/db",
    "db:studio": "npm run studio --workspace=@starvis/db",
    "quality:audit": "npm run quality:audit:contracts && npm run quality:audit:static-data -- --db-only && npm run quality:audit:data && npm run quality:audit:ui",
    "quality:audit:contracts": "node quality/api-contract-audit.mjs",
    "quality:audit:static-data": "npm run audit:static-data --workspace=@starvis/extractor --",
    "quality:audit:data": "node quality/api-data-audit.mjs",
    "quality:audit:data:prod": "node quality/api-data-audit.mjs --base-url https://starvis.ampynjord.bzh --strict",
    "quality:audit:ui": "npm run test:e2e --workspace=starvis-ihm -- --grep @critical",
    "sync": "npm run extract --workspace=@starvis/extractor -- --modules galactapedia,comm-links,starmap"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9"
  }
}
