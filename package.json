{
  "name": "starvis-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:generate": "npm run generate --workspace=@starvis/db",
    "db:push": "npm run push --workspace=@starvis/db",
    "db:studio": "npm run studio --workspace=@starvis/db"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9"
  }
}