# ============================================================
# STARVIS — Configuration production (VPS)
# Copier en .env.prod et ajuster les valeurs
# Usage : docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
# ============================================================

# --- Server ---
API_INTERNAL_PORT=3000       # Port interne du container (ne pas changer)
NODE_ENV=production
LOG_LEVEL=info               # debug | info | warn | error

# --- Security ---
ADMIN_API_KEY=change_me      # Clé admin forte (header X-API-Key)
CORS_ORIGIN=https://starvis.ampynjord.bzh

# --- Rate Limiting ---
RATE_LIMIT_MAX=200           # Hard limit par 15 min
RATE_LIMIT_BURST=30          # Burst limit par 1 min

# --- MySQL ---
DB_USER=starvis_user
DB_PASSWORD=change_me
DB_NAME=starvis
MYSQL_ROOT_PASSWORD=change_me
