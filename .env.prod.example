# STARVIS - production configuration
# Usage:
#   cp .env.prod.example .env.prod
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

COMPOSE_PROJECT_NAME=starvis
RESTART_POLICY=unless-stopped

# Images
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
API_IMAGE=ghcr.io/ampynjord/starvis-api:latest
IHM_IMAGE=ghcr.io/ampynjord/starvis-ihm:latest
BOT_IMAGE=ghcr.io/ampynjord/starvis-bot:latest

# Host bindings
DB_BIND_HOST=127.0.0.1
DB_EXTERNAL_PORT=5432

# Internal ports and service discovery
API_INTERNAL_PORT=3000
IHM_INTERNAL_PORT=8080
REDIS_INTERNAL_PORT=6379
API_HOST=api

# Runtime modes
API_NODE_ENV=production
IHM_NODE_ENV=production
BOT_NODE_ENV=production

# Healthchecks
HEALTHCHECK_INTERVAL=10s
HEALTHCHECK_TIMEOUT=5s
HEALTHCHECK_RETRIES=5
API_HEALTHCHECK_START_PERIOD=15s
IHM_HEALTHCHECK_INTERVAL=30s
IHM_HEALTHCHECK_TIMEOUT=3s
IHM_HEALTHCHECK_START_PERIOD=10s
IHM_HEALTHCHECK_RETRIES=3

# Domain and Traefik
DOMAIN=starvis.ampynjord.bzh
SITE_URL=https://starvis.ampynjord.bzh
TRAEFIK_NETWORK=traefik-network
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt
TRAEFIK_API_PRIORITY=90

# Container resource limits
POSTGRES_MEMORY_LIMIT=512M
REDIS_MEMORY_LIMIT=64M
API_MEMORY_LIMIT=256M
IHM_MEMORY_LIMIT=128M
BOT_MEMORY_LIMIT=128M

# PostgreSQL
DB_USER=starvis_user
DB_PASSWORD=starvis_pass
DB_NAME=starvis

# Redis
REDIS_MAXMEMORY=32mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# Security
ADMIN_API_KEY=
JWT_SECRET=
TWO_FACTOR_ENCRYPTION_KEY=
AUTH_COOKIE_NAME=starvis_token
CORS_ORIGIN=https://starvis.ampynjord.bzh

# Rate limiting - production defaults
RATE_LIMIT_MAX=200
RATE_LIMIT_BURST=30
RATE_LIMIT_ADMIN_MAX=100
RATE_LIMIT_AUTH_MAX=10

# API
LOG_LEVEL=info
CTM_CACHE_DIR=/app/ctm-cache
MISTRAL_API_KEY=
CHAT_PROVIDER_BASE_URL=https://api.mistral.ai/v1
CHAT_TOOL_MODEL=mistral-small-latest
CHAT_RESPONSE_MODEL=mistral-small-latest

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CONTACT_EMAIL=contact@example.com

# Legal notice / privacy page - fill with real production values before public deployment
NEXT_PUBLIC_CONTACT_EMAIL=contact@example.com
LEGAL_PUBLISHER_NAME=ampynjord
LEGAL_PUBLISHER_STATUS=Individual publisher - non-commercial community project
LEGAL_PUBLISHER_ADDRESS=Communicated to the hosting provider and available to competent authorities on lawful request.
LEGAL_PUBLISHER_PHONE=Available to competent authorities on lawful request.
LEGAL_HOST_NAME=OVH SAS
LEGAL_HOST_ADDRESS=2 rue Kellermann, 59100 Roubaix, France
LEGAL_HOST_PHONE=1007
NEXT_PUBLIC_CHAT_PROVIDER_NAME=Mistral AI
NEXT_PUBLIC_CHAT_PROVIDER_URL=https://mistral.ai

# IHM
NEXT_PUBLIC_SITE_URL=https://starvis.ampynjord.bzh
NEXT_PUBLIC_RSI_URL=https://robertsspaceindustries.com

# Discord bot
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
NEXT_PUBLIC_DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
NEXT_PUBLIC_DISCORD_GUILD_ID=931662690101895198
DISCORD_SERVER_INVITE_URL=
NEXT_PUBLIC_DISCORD_SERVER_INVITE_URL=
DISCORD_PRESENCE_INTERVAL_MS=60000
DISCORD_PRESENCE_STATUS=online
API_TOKEN=
