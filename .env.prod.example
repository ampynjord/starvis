# ============================================================
# STARVIS — Configuration production (VPS derrière Traefik)
# Usage : cp .env.prod.example .env.prod
#         docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
# ============================================================

# ── Projet Docker ───────────────────────────────────────────
COMPOSE_PROJECT_NAME=starvis

# ── Images Docker ───────────────────────────────────────────
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
API_IMAGE=ghcr.io/ampynjord/starvis-api:latest
IHM_IMAGE=ghcr.io/ampynjord/starvis-ihm:latest
BOT_IMAGE=ghcr.io/ampynjord/starvis-bot:latest

# ── Ports internes / accès local ────────────────────────────
API_INTERNAL_PORT=3000
REDIS_INTERNAL_PORT=6379
DB_EXTERNAL_PORT=5432

# ── Réseau interne inter-services ───────────────────────────
API_HOST=api

# ── Domaine et Traefik ──────────────────────────────────────
DOMAIN=starvis.example.com
SITE_URL=https://starvis.example.com
TRAEFIK_CERT_RESOLVER=letsencrypt
TRAEFIK_NETWORK=traefik-network

# ── Ressources conteneurs ───────────────────────────────────
POSTGRES_MEMORY_LIMIT=512M
REDIS_MEMORY_LIMIT=64M
REDIS_MAXMEMORY=32mb
API_MEMORY_LIMIT=256M
IHM_MEMORY_LIMIT=128M
BOT_MEMORY_LIMIT=128M

# ── Sécurité ────────────────────────────────────────────────
ADMIN_API_KEY=
JWT_SECRET=
CORS_ORIGIN=https://starvis.example.com

# ── Rate limiting (prod : strict) ───────────────────────────
RATE_LIMIT_MAX=200
RATE_LIMIT_BURST=30

# ── PostgreSQL ──────────────────────────────────────────────
DB_USER=starvis_user
DB_PASSWORD=starvis_pass
DB_NAME=starvis

# ── Log ─────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Mistral AI (chatbot Starvis) ─────────────────────────────
MISTRAL_API_KEY=


# ── Notifications email (bug reports) ───────────────────────
SMTP_HOST=                     # Ex : smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=                     # Ex : noreply@starvis.gg (optionnel, SMTP_USER par défaut)
CONTACT_EMAIL=                 # Adresse destinataire des rapports de bug

# ── SEO / Sitemap ────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://starvis.example.com

# ── Discord Bot ─────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=              # Laisser vide en prod (commandes globales)
API_TOKEN=
