{
  "manifest_version": 3,
  "name": "Starvis - Star Citizen Database & Toolset",
  "version": "0.1.0",
  "description": "Connects Starvis browser features, starting with RSI hangar synchronization for the Fleet Manager.",
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": ["tabs", "scripting"],
  "host_permissions": [
    "https://robertsspaceindustries.com/*",
    "https://starvis.ampynjord.bzh/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://starvis.ampynjord.bzh/*", "http://localhost/*", "http://127.0.0.1/*"],
      "js": ["src/starvis-content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://robertsspaceindustries.com/*"],
      "js": ["src/rsi-hangar-content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Starvis",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  }
}
