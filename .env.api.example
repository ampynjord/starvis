# ============================================================
# STARVIS API — Variables d'environnement
# Copier ce fichier en .env.api et remplir les valeurs
# ============================================================

# --- Base de données ---
DB_NAME=starvis
DB_USER=starvis_user
DB_PASSWORD=change_me_strong_password

# --- Sécurité ---
JWT_SECRET=change_me_random_64chars
ADMIN_API_KEY=change_me_admin_key

# --- API ---
API_PORT=127.0.0.1:3000
CORS_ORIGIN=https://votre-domaine.fr

# --- Optionnel ---
LOG_LEVEL=info
RATE_LIMIT_MAX=500
RATE_LIMIT_BURST=50
MISTRAL_API_KEY=
REDIS_MAXMEMORY=64mb

# --- Images (optionnel, latest par défaut) ---
# API_IMAGE=ghcr.io/ampynjord/starvis-api:1.2.3
# POSTGRES_IMAGE=postgres:16-alpine
# REDIS_IMAGE=redis:7-alpine

COMPOSE_PROJECT_NAME=starvis
