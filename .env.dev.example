# STARVIS - local development configuration
# Usage:
#   cp .env.dev.example .env.dev
#   docker compose -f docker-compose.dev.yml --env-file .env.dev up

COMPOSE_PROJECT_NAME=starvis
RESTART_POLICY=unless-stopped

# Images
NODE_DEV_IMAGE=node:22-alpine
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine

# Host bindings
API_BIND_HOST=0.0.0.0
IHM_BIND_HOST=0.0.0.0
DB_BIND_HOST=0.0.0.0
REDIS_BIND_HOST=0.0.0.0
API_PORT=3000
IHM_PORT=5173
DB_EXTERNAL_PORT=5432
REDIS_EXTERNAL_PORT=6379

# Internal ports and service discovery
API_INTERNAL_PORT=3000
IHM_INTERNAL_PORT=5173
REDIS_INTERNAL_PORT=6379
API_HOST=api

# Runtime modes
API_NODE_ENV=development
IHM_NODE_ENV=development
BOT_NODE_ENV=development

# Healthchecks
HEALTHCHECK_INTERVAL=10s
HEALTHCHECK_TIMEOUT=5s
HEALTHCHECK_RETRIES=5
API_HEALTHCHECK_START_PERIOD=15s

# PostgreSQL
DB_USER=starvis_user
DB_PASSWORD=starvis_pass
DB_NAME=starvis

# Redis
REDIS_MAXMEMORY=128mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# Security
ADMIN_API_KEY=
JWT_SECRET=
TWO_FACTOR_ENCRYPTION_KEY=
AUTH_COOKIE_NAME=starvis_token
CORS_ORIGIN=*

# Rate limiting - permissive for dev
RATE_LIMIT_MAX=500
RATE_LIMIT_BURST=200
RATE_LIMIT_ADMIN_MAX=500

# API
LOG_LEVEL=debug
CTM_CACHE_DIR=/app/ctm-cache
MISTRAL_API_KEY=
CHAT_PROVIDER_BASE_URL=https://api.mistral.ai/v1
CHAT_TOOL_MODEL=mistral-small-latest
CHAT_RESPONSE_MODEL=mistral-small-latest

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CONTACT_EMAIL=contact@example.com

# Legal notice / privacy page
NEXT_PUBLIC_CONTACT_EMAIL=contact@example.com
LEGAL_PUBLISHER_NAME=ampynjord
LEGAL_PUBLISHER_STATUS=Individual publisher
LEGAL_PUBLISHER_ADDRESS=Available on legitimate legal request through the contact email.
LEGAL_PUBLISHER_PHONE=Available on legitimate legal request through the contact email.
LEGAL_HOST_NAME=Local development host
LEGAL_HOST_ADDRESS=Local development environment
LEGAL_HOST_PHONE=Not applicable in local development
NEXT_PUBLIC_CHAT_PROVIDER_NAME=Mistral AI
NEXT_PUBLIC_CHAT_PROVIDER_URL=https://mistral.ai

# IHM
NEXT_PUBLIC_SITE_URL=http://localhost:5173
NEXT_PUBLIC_RSI_URL=https://robertsspaceindustries.com
CHOKIDAR_USEPOLLING=true
CHOKIDAR_INTERVAL=300
WATCHPACK_POLLING=true

# Discord bot
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
API_TOKEN=
SITE_URL=http://localhost:5173
