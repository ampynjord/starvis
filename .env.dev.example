# ============================================================
# STARVIS — Configuration développement local
# Usage : cp .env.dev.example .env.dev
#         docker compose -f docker-compose.dev.yml --env-file .env.dev up
# ============================================================

# ── Projet Docker ───────────────────────────────────────────
COMPOSE_PROJECT_NAME=starvis

# ── Ports exposés sur l'hôte ────────────────────────────────
API_PORT=3000                  # API REST
IHM_DEV_PORT=5173              # Next.js HMR (navigateur)
DB_EXTERNAL_PORT=5432          # PostgreSQL → outils SQL locaux (DBeaver, TablePlus…)
REDIS_EXTERNAL_PORT=6379       # Redis (optionnel)

# ── Ports internes des services ─────────────────────────────
API_INTERNAL_PORT=3000
IHM_INTERNAL_PORT=5173
REDIS_INTERNAL_PORT=6379

# ── Réseau interne inter-services ───────────────────────────
API_HOST=api

# ── Images Docker ───────────────────────────────────────────
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine

# ── Sécurité ────────────────────────────────────────────────
ADMIN_API_KEY=
JWT_SECRET=
CORS_ORIGIN=*
AUTH_COOKIE_NAME=starvis_token

# ── Rate limiting (dev : très permissif) ────────────────────
RATE_LIMIT_MAX=500
RATE_LIMIT_BURST=200
RATE_LIMIT_ADMIN_MAX=500

# ── PostgreSQL ──────────────────────────────────────────────
DB_USER=starvis_user
DB_PASSWORD=starvis_pass
DB_NAME=starvis

# ── Log ─────────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Mistral AI (chatbot Starvis) ────────────────────────────
MISTRAL_API_KEY=
CHAT_PROVIDER_BASE_URL=https://api.mistral.ai/v1
CHAT_TOOL_MODEL=mistral-small-latest
CHAT_RESPONSE_MODEL=mistral-small-latest

# ── Notifications email (bug reports) ───────────────────────
SMTP_HOST=                     # Laisser vide pour désactiver en dev
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CONTACT_EMAIL=

# ── SEO / Sitemap ────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:5173
NEXT_PUBLIC_RSI_URL=https://robertsspaceindustries.com

# ── Discord Bot (optionnel en dev) ──────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=              # ID serveur pour commandes instantanées (dev seulement)
API_TOKEN=
SITE_URL=http://localhost:5173
