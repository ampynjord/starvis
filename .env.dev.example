# ============================================================
# STARVIS — Configuration développement local
# Usage : cp .env.dev.example .env.dev
#         docker compose -f docker-compose.dev.yml --env-file .env.dev up
# Pour la production : voir .env.prod.example + docker-compose.prod.yml
# ============================================================

# --- API ---
API_PORT=3003                # Port exposé sur l'hôte (accès direct à l'API)
LOG_LEVEL=debug              # debug | info | warn | error

# --- IHM (Vite dev server) ---
IHM_DEV_PORT=5173            # Port exposé sur l'hôte (hot reload navigateur)

# --- Security ---
ADMIN_API_KEY=change_me      # Clé admin (header X-API-Key)
CORS_ORIGIN=*                # Dev: permissif

# --- Rate Limiting (dev: permissif) ---
RATE_LIMIT_MAX=500
RATE_LIMIT_BURST=200

# --- MySQL ---
DB_HOST=mysql                # Service docker interne (ne pas changer)
DB_PORT=3306                 # Port interne docker (ne pas changer)
DB_EXTERNAL_PORT=3307        # Port exposé sur l'hôte (outils SQL locaux, DBeaver…)
DB_USER=starvis_user
DB_PASSWORD=change_me
DB_NAME=starvis
MYSQL_ROOT_PASSWORD=change_me
