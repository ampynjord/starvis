# ============================================================
# STARVIS — Configuration locale (développement)
# Copier en .env et ajuster les valeurs
# Pour la production : voir .env.prod.example
# ============================================================

# --- Server ---
API_PORT=3003                # Port exposé sur l'hôte (dev local uniquement)
API_INTERNAL_PORT=3000       # Port interne du container (ne pas changer)
NODE_ENV=development
LOG_LEVEL=debug              # debug | info | warn | error

# --- Security ---
ADMIN_API_KEY=change_me      # Clé admin (header X-API-Key)
CORS_ORIGIN=*                # Dev: *  |  Prod: https://starvis.ampynjord.bzh

# --- Rate Limiting ---
RATE_LIMIT_MAX=500           # Hard limit par 15 min (dev: permissif)
RATE_LIMIT_BURST=200         # Burst limit par 1 min (dev: permissif)

# --- MySQL ---
DB_HOST=mysql                # Nom du service docker-compose
DB_PORT=3306                 # Port interne MySQL (dans le réseau docker)
DB_EXTERNAL_PORT=3307        # Port exposé sur l'hôte (dev: outils SQL locaux)
DB_USER=starvis_user
DB_PASSWORD=change_me
DB_NAME=starvis
MYSQL_ROOT_PASSWORD=change_me

# --- IHM (Frontend) ---
IHM_PORT=8080                # Port exposé (dev local uniquement)

# --- Extractor (optionnel, si extraction locale) ---
P4K_PATH=/game/Data.p4k
P4K_VOLUME=/home/user/sc-live  # Dossier LIVE de Star Citizen sur l'hôte
