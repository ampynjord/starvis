%%{init: {'theme': 'base', 'themeVariables': {'background': '#ffffff', 'mainBkg': '#ffffff', 'primaryColor': '#dbeafe', 'primaryBorderColor': '#3b82f6', 'secondaryColor': '#dcfce7', 'tertiaryColor': '#fef9c3', 'fontSize': '13px', 'fontFamily': 'Arial'}, 'flowchart': {'nodeSpacing': 25, 'rankSpacing': 60, 'useMaxWidth': true}}}%%
flowchart TD

    subgraph SRC["📦 Sources de données"]
        direction LR
        P4K["Data.p4k\n(fichiers jeu)"]
        RSI["RSI Ship Matrix\n(API officielle)"]
        CTM["CTM\n(modèles 3D)"]
    end

    subgraph EXT["⚙️ Extracteur CLI — TypeScript + Playwright"]
        direction LR
        DFS["DataForgeService\nparse XML/Zstd"]
        ES["ExtractionService\ncanonicalize + upsert"]
        RSS["RsiSyncService\nscraping RSI/CTM"]
    end

    subgraph DB["🗄️ PostgreSQL 16 — Prisma ORM"]
        direction LR
        GAME["Schéma game\nships, components,\nitems, missions, shops…"]
        RSI_S["Schéma rsi\nship_matrix,\ngalactapedia"]
        META["Schéma meta\nusers, extraction_log,\nchangelog"]
    end

    REDIS["🔴 Redis 7\nCache HTTP"]

    subgraph API["🚀 API Express.js — Node 22"]
        direction LR
        MW["Middleware\nHelmet · CORS · Rate limit\nJWT · Prometheus"]
        SVC["Services\nShipQuery · Loadout\nTrade · Crafting · Auth…"]
        DOC["Swagger UI\n/api-docs"]
    end

    subgraph FRONT["🌐 Interface Web — Next.js 15"]
        direction LR
        PAGES["Pages React 19\nVaisseaux · Composants\nMissions · Loadout…"]
        TQUERY["TanStack Query\ncache client"]
    end

    BOT["🤖 Bot Discord\ndiscord.js 14\n12+ commandes slash"]
    MISTRAL["🧠 Mistral AI\nChatbot /starvis"]

    %% Flux extraction
    P4K --> DFS
    RSI --> RSS
    CTM --> RSS
    DFS --> ES
    RSS --> ES
    ES -->|"INSERT ON CONFLICT\n(transaction atomique)"| GAME
    RSS --> RSI_S
    ES -->|"ExtractionLog\nChangelog"| META

    %% Flux runtime
    DB <-->|"Prisma queries"| SVC
    REDIS <-->|"ETag / cache"| API
    MW --> SVC
    SVC --> DOC

    %% Clients
    PAGES <-->|"HTTP / TanStack Query"| API
    BOT <-->|"REST calls"| API
    BOT <-->|"streaming"| MISTRAL
    PAGES <-->|"streaming"| MISTRAL

