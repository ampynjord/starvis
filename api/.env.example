# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=starvis
DB_PASSWORD=your_password_here
DB_NAME=starvis_db

# Redis (optional - cache disabled if unavailable)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# API Security
ADMIN_API_KEY=your_admin_key_here
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_MAX=200
RATE_LIMIT_BURST=60
