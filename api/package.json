{
  "name": "starvis",
  "version": "1.0.0",
  "description": "Starvis - REST API for Star Citizen ships",
  "main": "server.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "start": "tsx server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --write .",
    "lint:ci": "biome check .",
    "openapi:lint": "swagger-cli validate openapi.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "biome check --write --no-errors-on-unmatched",
      "vitest related --run --reporter=verbose"
    ],
    "*.prisma": [
      "prisma format",
      "prisma validate"
    ]
  },
  "keywords": [
    "star-citizen",
    "api"
  ],
  "overrides": {
    "effect": ">=3.20.0"
  },
  "author": "ampynjord - Dawnstar",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-slow-down": "^3.0.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "prisma": "^7.5.0",
    "prom-client": "^15.1.3",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.21.0",
    "winston": "^3.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@playwright/test": "^1.58.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.30",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "swagger-cli": "^4.0.4",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
